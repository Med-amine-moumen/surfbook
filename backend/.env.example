# ================================
# ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ================================

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/surf-booking

# JWT secret key (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Server port
PORT=5005

# Frontend URL (for CORS)
# For multiple frontends, separate URLs with commas.
FRONTEND_URL=http://localhost:3000

# Public backend URL used when returning uploaded image URLs.
# In production, set this to your deployed backend origin, without a trailing slash.
BACKEND_URL=http://localhost:5005
