# ================================
# FRONTEND ENVIRONMENT VARIABLES
# Copy this file to .env.local for local overrides.
# ================================

# Optional API backend URL.
# Local dev can leave this empty because next.config.js proxies /api and /uploads.
# In production, use the deployed backend origin or /api URL:
# NEXT_PUBLIC_API_URL=https://your-backend.example.com
# NEXT_PUBLIC_API_URL=https://your-backend.example.com/api
NEXT_PUBLIC_API_URL=

# Backend origin used by Next.js rewrites for /api/* and /uploads/*.
# Local development default is http://localhost:5005.
BACKEND_URL=http://localhost:5005
